<Window x:Class="Multiversions.Revit.Sample.Views.TestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewmodels="clr-namespace:Multiversions.Revit.Sample.ViewModels"
        xmlns:local="clr-namespace:Multiversions.Revit.Sample.Views"       
        mc:Ignorable="d"
        Height="620" Width="700" Title="MB Dev Tools" FontSize="20"
        ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/Style.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35"/>
            <RowDefinition Height="400"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right"                         
                        VerticalAlignment="Center"
                        Margin="0,0,20,0">
                <!-- Optional Label -->
                <TextBlock Text="Dark Mode" 
                           VerticalAlignment="Center" 
                           Margin="0,0,10,0" 
                           FontSize="14" 
                           FontWeight="SemiBold" 
                           Foreground="#333333"/>       

                <!-- Flat Toggle Button -->
                <ToggleButton Style="{StaticResource FlatThemeToggle}"
                              Checked="ThemeToggle_Checked"
                              Unchecked="ThemeToggle_Unchecked"
                              Command="{Binding ThemeChangeCommand}"/>   
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid Grid.Column="0">
                <Border 
                    Margin="20"
                    Background="#1E2530"
                    CornerRadius="10">
                    <StackPanel Margin="10">
                        <TextBlock
                            Text="Duct Creation"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="White"/>
                        <TextBlock
                            Style="{StaticResource SectionLabel}"
                            Text="Start Equipment"/>
                        <Button
                            Style="{StaticResource ModernButton}"
                            Background="#00B4FF"
                            Content="Start Equipment"
                            Command="{Binding SelectStartEquipmentCommand}"/>
                        <TextBlock
                            Style="{StaticResource SectionLabel}"
                            Text="End Equipment"/>
                        <Button
                            Style="{StaticResource ModernButton}"
                            Background="#00B4FF"
                            Content="End Equipment"
                            Command="{Binding SelectEndEquipmentCommand}"/>
                        <TextBlock
                            Style="{StaticResource SectionLabel}"
                            Text="Duct System Type"/>
                        <ComboBox
                            Style="{StaticResource ModernComboBox}"
                            ItemsSource="{Binding DuctSystemTypes}"
                            DisplayMemberPath="Name"
                            SelectedItem="{Binding SelectedDuctSystem}"/>
                        <TextBlock
                            Style="{StaticResource SectionLabel}"
                            Text="Duct Type"/>
                        <ComboBox
                            Style="{StaticResource ModernComboBox}"
                            ItemsSource="{Binding DuctTypes}"
                            DisplayMemberPath="Name"
                            SelectedItem="{Binding SelectedDuctType}"/>
                        <TextBlock
                            Style="{StaticResource SectionLabel}"
                            Text="Duct Level"/>
                        <ComboBox
                            Style="{StaticResource ModernComboBox}"
                            ItemsSource="{Binding DuctLevels}"
                            DisplayMemberPath="Name"
                            SelectedItem="{Binding SelectedLevel}"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Grid Grid.Column="1" >
                <!-- PREVIEW CARD -->
                <Border
                Margin="0,20,20,20"
                Background="#1E2530"
                CornerRadius="10">
                    <Grid>
                        <TextBlock
                        Text="3D Route Preview"
                        FontSize="22"
                        FontWeight="Bold"
                        Foreground="#00B4FF"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        <Grid Grid.Row="2" >
            <Border Margin="20,0,20,0"
                    Background="#1E2530"
                    CornerRadius="10"/>
        </Grid>
        <Grid Grid.Row="3">
            <StackPanel 
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,0,20,0">
                <Button
                    Width="140"
                    Height="40"
                    Margin="0,0,10,0"
                    Background="#16A34A"
                    Style="{StaticResource ModernButton}"
                    Content="Duct PlaceHolder"
                    Command="{Binding DuctPlaceHolderCreateCommand}"/>
                <Button
                    Width="140"
                    Height="40"
                    Background="#F97316"
                    Style="{StaticResource ModernButton}"
                    Content="Convert to Duct"
                    Command="{Binding ConvertToDuctCommand}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>